WECHAT_APPID=wx_your_appid_here
WECHAT_SECRET=your_wechat_secret_here
WECHAT_AUTHOR=your_author_name
# 微信 API 请求代理配置（例如 Clash Verge 默认本地混合端口，为空则不使用代理）
WECHAT_PROXY=http://127.0.0.1:7890

# VPS 远程执行配置（若配置，微信文章发布将在 VPS 上远程执行以使用固定 IP；留空则在本地执行）
VPS_IP=
VPS_PORT=22
VPS_USER=root
VPS_SSH_KEY=~/.ssh/id_rsa

